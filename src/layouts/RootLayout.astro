---
// STYLES //
import "../styles/global.css";
import "sal.js/dist/sal.css";

// COMPONENTS //
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Head from "../components/layout/Head.astro";

const {
  title = "Galaxy AI Navigator Labs",
  description = "Join the Galaxy AI Navigator Labs by Samsung & Reliance Digital. A hands-on masterclass powered by Samsung & Reliance Digital.",
  ogImage = "/images/og-image.jpg",
  ogUrl = "https://www.reliancedigital.in/",
} = Astro.props;
---

<html lang="en" class="scroll-smooth overflow-x-hidden">
  <!-- Head -->
  <head>
    <meta charset="UTF-8" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Head
      title={title}
      description={description}
      ogImage={ogImage}
      ogUrl={ogUrl}
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <!-- Body -->
  <body class="bg-background text-foreground overflow-x-hidden font-sans">
    <!-- Commion Header -->
    <Header />

    <!-- Pages content goes here -->
    <slot />

    <!-- Common Footer -->
    <Footer />

    <script type="module" is:inline>
      import sal from "https://cdn.skypack.dev/sal.js";
      sal({ threshold: 0.1, once: true });
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PMVF7LR0M5"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());
      gtag("config", "G-PMVF7LR0M5");
    </script>

    <script>
      import VanillaTilt from "vanilla-tilt";

      document.addEventListener("DOMContentLoaded", () => {
        const tiltCards = document.querySelectorAll(".tilt-card");
        VanillaTilt.init(tiltCards, {
          max: 20,
          speed: 400,
        });
      });
    </script>
  </body>
</html>
