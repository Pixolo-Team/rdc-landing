---
// COMPONENTS //
import FaqItems from "../components/FaqItems.astro";

// DATA //
import { faqSectionContent } from "../data/faq-data";
---

<!-- FAQ Section -->
<section
  class="w-full px-8 py-18 container mx-auto flex flex-col items-center gap-12"
>

  <div class="flex flex-col gap-0.5 justify-center items-center">
    <p class="text-blue-500 font-medium"> Q & A</p>
  <!-- Section Title Header -->
  <p
    class="primary-font section-title text-n-900 lg:text-5xl"
    data-sal="slide-up"
    data-sal-delay="200"
    data-sal-duration="300"
  >
    {faqSectionContent.title}
  </p>
  </div>
  

  <!-- FAQ List Component -->
  <FaqItems items={faqSectionContent.faqItemList} />
</section>
