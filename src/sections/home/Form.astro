---
// API SERVICES //
import { getAppointmentsCatalogRequest } from "../../services/api/dropdowns.api.service";

// TYPES //
import type { CatalogResponseData } from "../../types/dropdown";

// REACT ISLANDS //
import { ReactForm } from "../react-sections/ReactForm";

let catalog: CatalogResponseData = { items: [] };

try {
  const response = await getAppointmentsCatalogRequest();
  catalog = response.data ?? { items: [] };
} catch (error) {
  console.error("Catalog fetch failed:", error);
}
---

<ReactForm client:visible catalog={catalog} />
