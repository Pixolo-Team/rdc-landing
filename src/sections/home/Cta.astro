---
---

<section class="bg-n-50">
  <!-- Container -->
  <div class="container mx-auto px-5 py-32 md:px-0">
    <!-- CTA banner wrapper -->
    <div
      class="relative isolate overflow-hidden rounded-3xl px-8 py-8 md:h-[340px] md:px-8 md:py-8"
      data-sal="zoom-in"
      data-sal-duration="700"
    >
      <!-- Background artwork from Figma -->
      <div class="absolute inset-0 -z-10">
        <img
          src="/images/cta-mobile.png"
          alt=""
          class="h-full w-full object-cover object-bottom md:hidden"
        />
        <img
          src="/images/cta-desktop.png"
          alt=""
          class="hidden h-full w-full object-cover object-bottom md:block"
        />
      </div>

      <!-- CTA content -->
      <div class="flex min-h-[423px] flex-col items-start gap-11 md:min-h-0 md:w-[700px] md:justify-center md:gap-5">
        <!-- Copy block -->
        <div
          class="flex w-full flex-col items-start gap-3 text-blue-50"
          data-sal="slide-right"
          data-sal-delay="120"
          data-sal-duration="650"
        >
          <p class="primary-font text-2xl leading-none font-bold md:text-5xl">
            Limited Seats. High Demand !
          </p>
          <p class="primary-font text-sm leading-[1.25] font-medium md:text-xl">
            Each session has limited seats for hands-on experience. Registrations are filling fast
            across all urban centers.
          </p>
        </div>

        <!-- Primary action -->
        <div
          class="flex items-center"
          data-sal="fade-up"
          data-sal-delay="220"
          data-sal-duration="650"
        >
          <a
            href="#registerForm"
            class="primary-font rounded-3xl bg-n-50 px-5 py-3 text-center text-base leading-none font-bold text-n-900 md:px-7 md:py-3.5 md:text-xl"
          >
            Register Now
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
