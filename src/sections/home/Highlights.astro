---
import SectionHeader from "../../components/SectionHeader.astro";
import SvgIcon from "../../components/SvgIcon.astro";
import { highlightsSectionContent } from "../../data/highlights-data";
---

<section class="bg-n-50">
  <!-- Container -->
  <div class="container mx-auto px-5 py-8 md:px-0">
    <div class="flex flex-col items-center gap-16 pb-24 pt-20">
      <div data-sal="slide-down" data-sal-duration="600">
        <SectionHeader
          eyebrow={highlightsSectionContent.eyebrow}
          title={highlightsSectionContent.title}
        />
      </div>

      <!-- Highlight cards -->
      <div
        class="grid w-full grid-cols-1 justify-items-center gap-11 md:grid-cols-2 md:gap-8 md:px-10 xl:grid-cols-4"
      >
        {
          highlightsSectionContent.highlights.map((highlightsItem, index) => (
            <div
              class="flex h-full w-full max-w-[300px] flex-col items-center gap-4 md:gap-6"
              data-sal="fade-up"
              data-sal-delay={String(120 + index * 120)}
              data-sal-duration="650"
            >
              {/* Icon card */}
              <div class="flex aspect-square w-full items-center justify-center rounded-[28px] border border-n-200 bg-n-100 p-10 sm:max-w-[340px] sm:p-12 md:max-w-[360px] md:p-14">
                <div
                  class="h-[86px] w-[86px]"
                  aria-label={highlightsItem.alt}
                  role="img"
                >
                  <SvgIcon
                    name={highlightsItem.icon}
                    width="100%"
                    height="100%"
                    color="var(--color-blue-500)"
                  />
                </div>
              </div>

              {/* Text content */}
              <div class="flex w-full flex-col gap-1 px-3 text-center xl:px-2">
                <h3 class="text-n-900 text-2xl leading-tight font-bold text-left">
                  {highlightsItem.title}
                </h3>
                <p class="text-base leading-normal font-medium text-n-600 text-left">
                  {highlightsItem.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
