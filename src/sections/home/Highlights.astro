---
import { Image } from "astro:assets";
import SectionHeader from "../../components/SectionHeader.astro";
import { highlightsSectionContent } from "../../data/highlights-data";
---

<section class="bg-n-50">
  <!-- Container -->
  <div class="container mx-auto px-5 md:px-0">
    <div class="flex flex-col items-center gap-14 pb-32 pt-20">
      <div
        data-sal="slide-down"
        data-sal-duration="600"
      >
        <SectionHeader
          eyebrow={highlightsSectionContent.eyebrow}
          title={highlightsSectionContent.title}
        />
      </div>

      <!-- Highlight cards -->
      <div class="grid w-full justify-items-center grid-cols-1 gap-11 md:grid-cols-2 md:justify-items-stretch lg:grid-cols-4 md:px-5">
        {
          highlightsSectionContent.highlights.map((highlightsItem, index) => (
            <div
              class="mx-auto flex flex-col items-center gap-4 text-center md:mx-0 md:items-start md:gap-6 md:text-left"
              data-sal="fade-up"
              data-sal-delay={String(120 + index * 120)}
              data-sal-duration="650"
            >
              {/* Icon card */}
              <div class="flex aspect-square w-full max-w-[320px] items-center justify-center rounded-[28px] border border-n-200 bg-n-100 p-10 sm:max-w-[340px] sm:p-12 md:max-w-[360px] md:p-14">
                <Image
                  src={highlightsItem.image}
                  alt={highlightsItem.alt}
                  width={86}
                  height={86}
                  class="h-[86px] w-[86px]"
                />
              </div>

              {/* Text content */}
              <div class="flex w-full flex-col items-center gap-1 px-1.5 md:items-start">
                <h3 class="text-n-900 text-2xl leading-none font-bold">
                  {highlightsItem.title}
                </h3>
                <p class="text-base leading-[1.5] font-medium text-n-600">
                  {highlightsItem.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
