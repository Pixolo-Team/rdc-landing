---
const phoneImage = "https://www.figma.com/api/mcp/asset/8a538545-b2bf-4b6d-9ef5-1159a124bb07";
const hashVector = "https://www.figma.com/api/mcp/asset/c173f3cb-93f6-45d5-868b-a3046def5854";
const hashGroupTopLeft = "https://www.figma.com/api/mcp/asset/1fbfcf4f-3b7d-42f4-8467-cb8aad55d5ff";
const hashGroupTopRight = "https://www.figma.com/api/mcp/asset/d15db588-c1d2-453e-9432-ac3b6cdbdb0a";
const hashGroupBottomLeft = "https://www.figma.com/api/mcp/asset/e70b91f2-4560-4bc7-a5af-020176a678fa";
const hashStarDot = "https://www.figma.com/api/mcp/asset/db54f3af-9389-4615-970f-f5068c584679";
const hashStarShape = "https://www.figma.com/api/mcp/asset/5dc3a5c5-21b5-4b7d-b76e-9cb0ccbc255d";
const hashStarFill = "https://www.figma.com/api/mcp/asset/346139f1-90a5-4e27-8944-8908e3f9fd8f";
---

<section
  class="relative overflow-hidden bg-n-50 py-20 sm:py-24 lg:py-28 xl:py-36"
  data-name="about"
  data-node-id="2001:950"
>
  <img
    src={phoneImage}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-32 -left-28 w-[240px] max-w-none sm:-bottom-44 sm:-left-24 sm:w-[300px] lg:-bottom-56 lg:-left-18 lg:w-[420px] xl:-bottom-72 xl:left-[3.5rem] xl:w-[364px]"
  />

  <div class="container mx-auto px-6 sm:px-10" data-name="container" data-node-id="2001:1236">
    <div
      class="mx-auto flex max-w-[858px] flex-col items-center gap-12 text-center sm:gap-14 lg:gap-16"
      data-name="content"
      data-node-id="2001:1240"
    >
      <div
        class="flex w-full flex-col items-center gap-1"
        data-name="title"
        data-node-id="2001:1238"
      >
        <p
          class="font-medium text-[13px] tracking-tight text-blue-500 sm:text-base"
          style="font-family: 'SecondaryFont', sans-serif;"
          data-node-id="2001:1076"
        >
          MEET YOUR NEW AI PHONE
        </p>
        <h2
          class="max-w-[17ch] font-bold text-[2rem] leading-none tracking-[-0.04em] text-n-900 sm:max-w-none sm:text-[2.75rem] lg:text-[3rem]"
          style="font-family: 'SecondaryFont', sans-serif;"
          data-node-id="2001:1073"
        >
          Built for the way you live and learn.
        </h2>
      </div>

      <p
        class="max-w-[22ch] text-pretty text-[1.5rem] font-bold leading-[1.5] text-n-800 sm:max-w-[28ch] sm:text-[1.75rem] lg:max-w-none lg:text-[1.875rem]"
        style="font-family: 'SecondaryFont', sans-serif;"
        data-node-id="2001:1074"
      >
        This isn’t a demo. It’s a hands-on AI experience. In 60–90 minutes, you’ll learn how to
        actually use AI in your daily life, from notes to content to productivity.
      </p>

      <div
        class="relative h-[44px] w-[189px] shrink-0"
        data-name="hash"
        data-node-id="2001:1141"
        aria-label="Your Guide To Galaxy AI"
      >
        <img
          src={hashVector}
          alt=""
          aria-hidden="true"
          class="absolute left-0 top-0 h-[44px] w-[50px]"
        />
        <img
          src={hashGroupTopLeft}
          alt=""
          aria-hidden="true"
          class="absolute left-[57px] top-[2px] h-[16px] w-[47px]"
        />
        <img
          src={hashGroupTopRight}
          alt=""
          aria-hidden="true"
          class="absolute left-[109px] top-0 h-[18px] w-[62px]"
        />
        <img
          src={hashGroupBottomLeft}
          alt=""
          aria-hidden="true"
          class="absolute left-[50px] top-[24px] h-[20px] w-[115px]"
        />
        <div class="absolute left-[169px] top-[18px] h-[16px] w-[20px]" aria-hidden="true">
          <img src={hashStarDot} alt="" class="absolute left-[3px] top-0 h-[5px] w-[5px]" />
          <img src={hashStarDot} alt="" class="absolute left-[14px] top-[10px] h-[5px] w-[5px]" />
          <img src={hashStarShape} alt="" class="absolute left-0 top-[4px] h-[12px] w-[9px]" />
          <img src={hashStarFill} alt="" class="absolute left-[5px] top-[2px] h-[16px] w-[14px]" />
        </div>
      </div>
    </div>
  </div>
</section>
