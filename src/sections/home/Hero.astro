---
import { Image } from "astro:assets";
import SvgIcon from "../../components/SvgIcon.astro";
import galaxyAiLogoDark from "../../assets/galaxy-ai-logo-dark.svg";
import galaxyAiLogoLight from "../../assets/galaxy-ai-logo-light.svg";
import heroPhone from "../../assets/hero-mobile.png";

const valueProps = [
  { label: "Free to attend", icon: "CheckCircle" },
  { label: "Limited seats", icon: "Chair3" },
  { label: "Get Certified", icon: "DocumentCertificate" },
];

const attendees = [
  { initials: "JP", bgClass: "bg-orange-500" },
  { initials: "AA", bgClass: "bg-teal-500" },
  { initials: "+5k", bgClass: "bg-indigo-500" },
];
---

<section class="hero-section">
  <!-- Hero container -->
  <div class="container mx-auto px-5 pt-36 md:pt-40 md:px-8 lg:pt-50">
    <div class="flex flex-col gap-10 xl:flex-row md:items-start md:gap-38 md:justify-between xl:items-end">
      
      <!-- Left content block -->
      <div class="flex flex-col gap-12 md:gap-16 xl:pb-18">
        <!-- Intro content -->
        <div class="flex flex-col gap-12 md:gap-[42px]">
          <!-- Experience label and Galaxy AI wordmark -->
          <div
            class="flex max-w-[321px] flex-col items-start gap-1"
            data-sal="slide-right"
            data-sal-duration="700"
          >
            <p class="primary-font text-lg font-bold text-n-900">Experience</p>

            <!-- Theme-aware Galaxy AI logo -->
            <div class="w-[250px] md:w-[321px]">
              <Image
                src={galaxyAiLogoLight}
                alt="Galaxy AI"
                class="show-in-light hide-in-dark block w-full"
                width={300}
                height={68}
              />
              <Image
                src={galaxyAiLogoDark}
                alt="Galaxy AI"
                class="hide-in-light show-in-dark block w-full"
                width={321}
                height={68}
              />
            </div>
          </div>

          <!-- Main hero copy -->
          <div
            class="flex flex-col items-start gap-5"
            data-sal="slide-right"
            data-sal-delay="120"
            data-sal-duration="750"
          >
            <div class="secondary-font flex flex-col text-left text-4xl leading-[1] font-bold md:text-6xl">
              <p class="text-n-900 leading-tight">Join the
              <span class="bg-gradient-to-r from-[#9a9af8] via-[#747cf9] to-[#3b57fe] bg-clip-text text-transparent">
                Galaxy AI
              </span></p>
              <p class="text-n-900">Navigator Labs</p>
            </div>

            <p class="primary-font font-medium text-sm text-n-900 leading-relaxed md:text-lg">
              A hands-on masterclass powered by Samsung & Reliance Digital.
            </p>
          </div>

          <!-- Value props -->
          <div
            class="flex flex-wrap gap-4"
            data-sal="fade-up"
            data-sal-delay="180"
            data-sal-duration="700"
          >
            {
              valueProps.map((item) => (
                <div class="flex items-center gap-2 rounded-full bg-n-200 px-2 py-2">
                  <div class="h-[15px] w-[15px] xl:w-[22px] xl:h-[22px]">
                    <SvgIcon name={item.icon} width="100%" height="100%" color="var(--color-indigo-500)"  />
                  </div>
                  <p class="secondary-font relative top-[-0.06em] block leading-[0.82] text-xs font-bold uppercase text-n-900 md:text-sm">
                    {item.label}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <!-- CTA and social proof -->
        <div
          class="flex flex-col gap-6 items-center md:flex-row md:items-start"
          data-sal="fade-up"
          data-sal-delay="260"
          data-sal-duration="750"
        >
          <!-- CTA button -->
          <div class="flex w-full flex-col items-center gap-5 md:w-auto">
            <a
              href="#registerForm"
              class="secondary-font flex w-full items-center justify-center rounded-full bg-indigo-500 px-8 py-3.5 text-2xl font-bold text-blue-50 md:text-2xl"
            >
              Register Now
            </a>
            <p class="primary-font text-center text-sm text-n-500">Registration ends soon</p>
          </div>

          <!-- Attendance proof -->
          <div class="flex items-center gap-2.5 py-1.5">
            <div class="flex items-center pr-5">
              {
                attendees.map((attendee) => (
                  <div class:list={[
                    "mr-[-20px] flex size-[49.096px] items-center justify-center rounded-full border border-n-50 text-lg text-n-50",
                    "primary-font font-medium",
                    attendee.bgClass,
                  ]}>
                    {attendee.initials}
                  </div>
                ))
              }
            </div>
            <p class="primary-font text-base text-n-700">people are attending</p>
          </div>
        </div>
      </div>

      <!-- Right visual block -->
      <div
        class="relative mt-20 flex items-end justify-center w-full md:mt-0 md:min-w-0 md:flex-1"
        data-sal="slide-left"
        data-sal-delay="180"
        data-sal-duration="800"
      >
        <!-- Tilted guide badge -->
        <div class="absolute left-1/2 -translate-x-1/2 top-[-61px] z-10 md:top-[-92px] xl:top-[-72px] xl:left-2/3">
          <div class="w-[230px] -rotate-[7.22deg] rounded-[24px] bg-n-100 px-6 py-5 shadow-[0px_4px_8.3px_5px_rgba(0,0,0,0.08)] md:w-[380px] md:px-10 md:py-7 xl:w-[300px]">
                <SvgIcon name="hashtag" width="100%" height="100%" color="var(--color-n-900)" />
          </div>
        </div>

        <!-- Phone artwork -->
        <div class="w-full translate-y-[10px] flex justify-center px-4 md:w-[510px]">
          <Image
            src={heroPhone}
            alt="Samsung Galaxy phones"
            width={530}
            height={676}
            class="hero-phone-artwork pointer-events-none h-auto w-full max-w-[70vw]"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>

  const initHeroPhoneRotation = () => {
    const section = document.querySelector(".hero-section");
    const artwork = document.querySelector(".hero-phone-artwork");

    if (!(section instanceof HTMLElement) || !(artwork instanceof HTMLElement)) return;

    const updateRotation = () => {
      const rect = section.getBoundingClientRect();
      
      const viewportHeight = window.innerHeight || 1;

      const progress = -1*rect.top;
      const clamped = Math.max(0, progress);
      const rotationY = clamped*0.04;
      artwork.style.transform = `perspective(1400px) rotateY(${rotationY.toFixed(2)}deg)`;
    };

    updateRotation();

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        updateRotation();
        ticking = false;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroPhoneRotation, { once: true });
  } else {
    initHeroPhoneRotation();
  }
</script>
