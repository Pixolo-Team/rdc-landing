---
// COMPONENTS //
import { Image } from "astro:assets";
import SvgIcon from "../../components/SvgIcon.astro";

// IMAGES //
import heroPhone from "../../assets/hero-mobile.png";

// SVG's //
import galaxyAiLogoDark from "../../assets/galaxy-ai-logo-dark.svg";
import galaxyAiLogoLight from "../../assets/galaxy-ai-logo-light.svg";

const attendees = [
  { initials: "JP", bgClass: "bg-orange-500" },
  { initials: "AA", bgClass: "bg-teal-500" },
  { initials: "+5k", bgClass: "bg-indigo-500" },
];
---

<section class="hero-section">
  <!-- Hero container -->
  <div class="container mx-auto px-5 pt-36 md:pt-40 md:px-8 lg:pt-50">
    <div
      class="flex flex-col gap-10 xl:flex-row md:items-start md:gap-36 lg:gap-38 md:justify-between xl:items-end"
    >
      <!-- Left content block -->
      <div
        class="flex flex-col gap-12 w-full md:gap-16 xl:max-w-[660px] xl:pb-18"
      >
        <!-- Intro content -->
        <div class="flex flex-col gap-12 md:gap-[42px]">
          <!-- Experience label and Galaxy AI wordmark -->
          <div
            class="flex max-w-[321px] flex-col items-start gap-1"
            data-sal="slide-right"
            data-sal-duration="700"
          >
            <p class="primary-font text-lg font-bold text-n-900">Experience</p>

            <!-- Theme-aware Galaxy AI logo -->
            <div class="w-[250px] md:w-[321px]">
              <Image
                src={galaxyAiLogoLight}
                alt="Galaxy AI"
                class="show-in-light hide-in-dark block w-full"
                width={300}
                height={68}
              />
              <Image
                src={galaxyAiLogoDark}
                alt="Galaxy AI"
                class="hide-in-light show-in-dark block w-full"
                width={321}
                height={68}
              />
            </div>
          </div>

          <!-- Main hero copy -->
          <div
            class="flex w-full flex-col items-center gap-5 text-center"
            data-sal="slide-right"
            data-sal-delay="120"
            data-sal-duration="750"
          >
            <!-- Light mode masterclass image -->
            <div
              class="show-in-light hide-in-dark w-[90%] md:max-w-[410px] 2xl:max-w-[440px]"
            >
              <img
                src="/images/new-masterclass-logo.png"
                alt="Digital Playground Masterclass"
                class="hero-masterclass-logo block h-auto w-full"
              />
            </div>

            <!-- Dark mode masterclass image -->
            <div
              class="hide-in-light show-in-dark w-[90%] md:max-w-[410px] 2xl:max-w-[440px]"
            >
              <img
                src="/images/new-masterclass-logo-dark.png"
                alt="Digital Playground Masterclass"
                class="hero-masterclass-logo hero-masterclass-logo--dark block h-auto w-full"
              />
            </div>

            <!-- Subtitle text -->
            <p
              class="primary-font w-full text-sm leading-relaxed font-medium text-n-900 md:w-[75%] lg:w-[60%] xl:w-[78%] md:text-lg"
            >
              Join the PlAiground Masterclass powered by Reliance Digital and
              Samsung
            </p>
          </div>
        </div>

        <!-- CTA and social proof -->
        <div
          class="flex flex-col gap-6 items-start md:flex-row"
          data-sal="fade-up"
          data-sal-delay="260"
          data-sal-duration="750"
        >
          <!-- CTA button -->
          <div class="flex w-auto flex-col items-center gap-5">
            <a
              href="#registerForm"
              class="hero-register-cta secondary-font flex w-full items-center justify-center rounded-full px-8 py-3.5 text-2xl font-bold text-blue-50 md:text-2xl"
            >
              <span class="hero-cta-label">Register Now</span>
            </a>
            <p class="primary-font text-center font-medium text-sm text-n-500">
              Registration ends soon
            </p>
          </div>

          <!-- Attendance proof -->
          <div class="flex items-center gap-2.5 py-1.5">
            <div class="flex items-center pr-5">
              {
                attendees.map((attendee) => (
                  <div
                    class:list={[
                      "mr-[-20px] flex size-[49.096px] items-center justify-center rounded-full border border-n-50 text-lg text-n-50",
                      "primary-font font-medium",
                      attendee.bgClass,
                    ]}
                  >
                    {attendee.initials}
                  </div>
                ))
              }
            </div>
            <p class="primary-font font-medium text-base text-n-700">
              people are attending
            </p>
          </div>
        </div>
      </div>

      <!-- Right visual block -->
      <div
        class="relative mt-20 flex items-end justify-center w-full md:mt-0 md:min-w-0 md:flex-1"
        data-sal="slide-left"
        data-sal-delay="180"
        data-sal-duration="800"
      >
        <!-- Tilted guide badge -->
        <div
          class="absolute left-1/2 -translate-x-1/2 top-[-61px] z-10 md:top-[-92px] xl:top-[-72px] xl:left-2/3"
        >
          <div
            class="hero-guide-badge w-[230px] -rotate-[7.22deg] rounded-[24px] bg-n-100 px-6 py-5 shadow-[0px_4px_8.3px_5px_rgba(0,0,0,0.08)] md:w-[380px] md:px-10 md:py-7 xl:w-[300px]"
          >
            <SvgIcon
              name="hashtag"
              width="100%"
              height="100%"
              color="var(--color-n-900)"
            />
          </div>
        </div>

        <!-- Phone artwork -->
        <div
          class="w-full translate-y-4 md:translate-y-8 xl:translate-y-4 flex justify-center px-4 md:w-[510px]"
        >
          <Image
            src={heroPhone}
            alt="Samsung Galaxy phones"
            width={530}
            height={676}
            class="hero-phone-artwork pointer-events-none h-auto w-full max-w-[70vw]"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-masterclass-logo {
    width: 100%;
  }

  .hero-guide-badge {
    animation: hero-guide-badge-float 4.8s ease-in-out infinite;
    transform-origin: center center;
    will-change: transform;
  }

  .hero-register-cta {
    --hero-cta-shadow: 0 8px 22px
      color-mix(in srgb, var(--color-indigo-900) 24%, transparent);
    --hero-cta-shadow-hover: 0 12px 30px
      color-mix(in srgb, var(--color-indigo-900) 34%, transparent);
    --hero-cta-highlight: color-mix(
      in srgb,
      var(--color-blue-50) 72%,
      transparent
    );
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-blue-50) 18%, transparent);
    background: linear-gradient(
      135deg,
      var(--color-indigo-300) 0%,
      var(--color-indigo-500) 55%,
      var(--color-blue-500) 100%
    );
    background-size: 160% 160%;
    box-shadow: var(--hero-cta-shadow);
    transition:
      transform 320ms ease,
      box-shadow 320ms ease,
      filter 320ms ease,
      background-position 420ms ease;
  }

  .hero-register-cta::before {
    content: "";
    position: absolute;
    inset: 1px;
    z-index: 0;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-blue-50) 18%, transparent) 0%,
      transparent 55%,
      color-mix(in srgb, var(--color-indigo-950) 8%, transparent) 100%
    );
    opacity: 0.9;
  }

  .hero-register-cta::after {
    content: "";
    position: absolute;
    inset: -140% auto auto -30%;
    z-index: 1;
    width: 38%;
    height: 360%;
    transform: rotate(22deg);
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--hero-cta-highlight) 50%,
      transparent 100%
    );
    opacity: 0;
    transition:
      transform 620ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 320ms ease;
  }

  .hero-cta-label {
    position: relative;
    z-index: 2;
    letter-spacing: 0.01em;
  }

  .hero-register-cta:hover,
  .hero-register-cta:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--hero-cta-shadow-hover);
    filter: saturate(1.08);
    background-position: 100% 50%;
  }

  .hero-register-cta:hover::after,
  .hero-register-cta:focus-visible::after {
    transform: translateX(340%) rotate(22deg);
    opacity: 1;
  }

  .hero-register-cta:focus-visible {
    outline: 3px solid
      color-mix(in srgb, var(--color-blue-100) 88%, transparent);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-register-cta,
    .hero-register-cta::after {
      transition: none;
    }

    .hero-guide-badge {
      animation: none;
    }

    .hero-register-cta:hover,
    .hero-register-cta:focus-visible {
      transform: none;
    }

    .hero-register-cta:hover::after,
    .hero-register-cta:focus-visible::after {
      opacity: 0;
      transform: rotate(22deg);
    }
  }

  @keyframes hero-guide-badge-float {
    0%,
    100% {
      transform: translateY(0) rotate(-7.22deg);
    }
    50% {
      transform: translateY(-10px) rotate(-6deg);
    }
  }
</style>

<script is:inline>
  const initHeroPhoneRotation = () => {
    const section = document.querySelector(".hero-section");
    const artwork = document.querySelector(".hero-phone-artwork");

    if (!(section instanceof HTMLElement) || !(artwork instanceof HTMLElement))
      return;

    const updateRotation = () => {
      const rect = section.getBoundingClientRect();

      const progress = -1 * rect.top;
      const clamped = Math.max(0, progress);
      const rotationY = clamped * 0.04;
      artwork.style.transform = `perspective(1400px) rotateY(${rotationY.toFixed(2)}deg)`;
    };

    updateRotation();

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        updateRotation();
        ticking = false;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroPhoneRotation, {
      once: true,
    });
  } else {
    initHeroPhoneRotation();
  }
</script>
