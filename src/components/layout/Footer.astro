---
import { Image } from "astro:assets";

const sectionContent = {
  contact_number: "+91-93250-99635",
  email: "support@reliancedigitalcommunity.com",
  title: "Galaxy AI Navigator Labs",
  description:
    "A collaboration between Samsung and Reliance Digital to pioneer AI literacy in India.",
  year: new Date().getFullYear(),
  facebook_url: "https://m.facebook.com/reliancedigital/",
  x_url: "https://x.com/RelianceDigital",
  insta_url:
    "https://www.instagram.com/reliance_digital?igsh=MTdncmp6MTJiNmJzYw==",
};
---

<footer class="bg-n-50 pt-12 xl:pt-24">
  <div class="container mx-auto py-12 lg:py-2">
    <div class="flex flex-col gap-16 items-start md:gap-13 lg:gap-10">

      <div class="flex w-full flex-col max-w-[500px] items-centre gap-2.5 text-left lg:px-8">
        <p class="text-n-950 text-[28px] font-semibold sm:text-3xl lg:text-2xl;">{sectionContent.title}</p>
        <p class="primary-font text-base font-normal text-n-900">
          {sectionContent.description}
        </p>
      </div>

      <div
        class="flex flex-col gap-16 items-center md:gap-13 lg:flex-row lg:justify-between lg:w-full lg:px-8 lg:items-end"
      >
        <!-- Support -->
        <div class="flex flex-col gap-5 lg:items-start">
          <h3 class="sub-title">For Support</h3>

          <div class="flex flex-col gap-2 items-center lg:items-start">
            <!-- Call -->
            <p class="text-center">
              <span class="para-text text-lg lg:text-2xl">Call:</span>
              <a
                href={`tel:${sectionContent.contact_number}`}
                class="para-text text-lg lg:text-2xl text-sky-600 hover:underline lg:ml-2"
              >
                {sectionContent.contact_number}
              </a>
            </p>
            <!-- Email -->
            <p class="text-center">
              <span class="para-text text-lg lg:text-2xl">Email:</span>
              <a
                href={`mailto:${sectionContent.email}`}
                class="para-text text-lg lg:text-2xl text-sky-600 hover:underline lg:ml-2"
              >
                {sectionContent.email}
              </a>
            </p>
          </div>
        </div>

       
          <!-- Certification Partner -->
          <div class="flex flex-col items-center gap-5 lg:self-end lg:items-start lg:pb-1">
            <div
              class="relative flex items-center gap-2.5 md:gap-3"
            >
              <p class="primary-font text-n-900 text-[29px] leading-none font-bold md:text-[44px]">
                Galaxy AI
              </p>

              <Image
                src="/images/stars.svg"
                alt=""
                width={44}
                height={44}
                class="h-7 w-7 md:h-11 md:w-11"
                aria-hidden="true"
              />
            </div>
          </div>
      </div>

      <!-- Footer Bottom -->
      <div class="flex flex-col w-full gap-2 items-center lg:gap-0 lg:px-8">
        <!-- A divider -->
        <hr class="w-4/5 text-n-300 lg:w-full" />

        <div
          class="flex flex-col gap-2 items-center pt-2 lg:w-full lg:pt-0 lg:justify-between lg:flex-row"
        >
          <!-- Copyright Text -->
          <p class="text-base text-n-700">
            Copyright © {sectionContent.year}. All Rights Reserved.
          </p>

          <div class="flex flex-col gap-2 items-center lg:flex-row-reverse">
            <!-- Socials: square buttons using n tokens -->
            <div
              class="flex gap-7 py-6 lg:gap-2"
              data-sal="slide-up"
              data-sal-duration="500"
              data-sal-easing="ease-out-back"
            >
              <!-- Facebook -->
              <a
                href={sectionContent.facebook_url}
                target="_blank"
                aria-label="Facebook"
                class="w-14 lg:w-6 transition-transform duration-200 hover:scale-110"
              >
                <img src="/icons/facebook.svg" class="experience-card-icon w-full" />
              </a>

              <!-- X -->
              <a
                href={sectionContent.x_url}
                target="_blank"
                aria-label="X"
                class="w-14 lg:w-6 transition-transform duration-200 hover:scale-110"
              >
                <img src="/icons/x.svg" class="experience-card-icon w-full" />
              </a>

              <!-- Insta -->
              <a
                href={sectionContent.insta_url}
                target="_blank"
                aria-label="Insta"
                class="w-14 lg:w-6 transition-transform duration-200 hover:scale-110"
              >
                <img src="/icons/insta.svg" class="experience-card-icon w-full" />
              </a>
            </div>

            <!-- Privacy & Terms -->
            <nav aria-label="Footer links" class="text-sm text-n-950">
              <a
                href="https://www.reliancedigital.in/c/privacy-policy"
                target="_blank"
                class="hover:underline">Privacy Policy</a
              >
              <span class="mx-px text-n-400">|</span>
              <a
                href="https://www.reliancedigital.in/c/terms-of-use"
                target="_blank"
                class="hover:underline">Terms &amp; Conditions</a
              >
            </nav>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
